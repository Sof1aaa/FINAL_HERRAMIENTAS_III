<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - HERRAMIENTAS</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Estilos -->
    <style>
            body {
                background: #f4f6f9;
            }

            .card {
                border-radius: 15px;
            }

            /* Ocultar opciones innecesarias de Identity */
            a[href*="Register"],
            a[href*="ForgotPassword"],
            a[href*="ResendEmailConfirmation"] {
                display: none !important;
            }
    </style>
</head>

<body>

    @if (User.Identity.IsAuthenticated)
    {
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container-fluid">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    HERRAMIENTAS
                </a>

                <div class="collapse navbar-collapse">
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Categorias" asp-action="Index">Categorías</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Productos" asp-action="Index">Productos</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Clientes" asp-action="Index">Clientes</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Pedidos" asp-action="Index">Pedidos</a>
                        </li>

                    </ul>

                    <span class="text-white me-3">
                        Hola @User.Identity?.Name
                    </span>

                    <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                        <button class="btn btn-outline-light">Cerrar sesión</button>
                    </form>
                </div>

            </div>
        </nav>
    }

    <div class="container mt-4">
        @RenderBody()
    </div>

</body>
</html>