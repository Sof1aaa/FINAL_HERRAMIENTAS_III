@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">Bienvenido/a</h2>

<div class="row">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5>Categorías</h5>
                <a asp-controller="Categorias" class="btn btn-light btn-sm">Ver</a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5>Productos</h5>
                <a asp-controller="Productos" class="btn btn-light btn-sm">Ver</a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body">
                <h5>Clientes</h5>
                <a asp-controller="Clientes" class="btn btn-light btn-sm">Ver</a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-danger mb-3">
            <div class="card-body">
                <h5>Pedidos</h5>
                <a asp-controller="Pedidos" class="btn btn-light btn-sm">Ver</a>
            </div>
        </div>
    </div>
</div>