@model Pedido

<div class="card shadow-lg p-4">

    <h2 class="mb-4 text-primary">✏️ Editar Pedido</h2>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Id" />

        <!-- Cliente -->
        <div class="mb-3">
            <label class="form-label fw-bold">Cliente</label>
            <select asp-for="ClienteId"
                    asp-items="(IEnumerable<SelectListItem>)ViewBag.Clientes"
                    class="form-select">
            </select>
        </div>

        <!-- Productos -->
        <div class="mb-3">
            <label class="form-label fw-bold">Productos</label>

            <div class="list-group">

                @foreach (var item in (List<Producto>)ViewBag.Productos)
                {
                    var detalle = Model.PedidoProductos
                        .FirstOrDefault(dp => dp.ProductoId == item.Id);

                    bool seleccionado = detalle != null;
                    int cantidad = detalle?.Cantidad ?? 1;

                    <div class="list-group-item d-flex justify-content-between align-items-center">

                        <div>
                            <input type="checkbox"
                                   name="ProductoIds"
                                   value="@item.Id"
                                   class="form-check-input me-2"
                            @(seleccionado ? "checked" : "")
                            @(item.Stock <= 0 && !seleccionado ? "disabled" : "") />

                            <strong>@item.Nombre</strong>
                            <span class="text-muted">($@item.Precio)</span>

                            @if (item.Stock > 0)
                            {
                                <span class="badge bg-success ms-2">
                                    Stock: @item.Stock
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger ms-2">
                                    Sin stock
                                </span>
                            }
                        </div>

                        <input type="number"
                               name="Cantidades"
                               value="@cantidad"
                               class="form-control"
                               style="width: 100px;"
                               min="1"
                               max="@item.Stock"
                        @(item.Stock <= 0 && !seleccionado ? "disabled" : "") />
                    </div>
                }

            </div>
        </div>

        <!-- TOTAL -->
        <div class="text-end mb-3">
            <h5>Total: <span id="total">$0</span></h5>
        </div>

        <!-- Botones -->
        <div class="d-flex justify-content-between mt-4">

            <a asp-action="Index" class="btn btn-secondary">
                Volver
            </a>

            <button type="submit" class="btn btn-success px-4">
                Actualizar Pedido
            </button>

        </div>

    </form>
</div>

<script>
    const checkboxes = document.querySelectorAll('input[name="ProductoIds"]');
    const cantidades = document.querySelectorAll('input[name="Cantidades"]');

    function calcularTotal() {
        let total = 0;

        checkboxes.forEach((chk, index) => {
            if (chk.checked) {
                const precio = parseFloat(
                    chk.parentElement.querySelector("span.text-muted")
                        .innerText.replace(/[^\d.]/g, '')
                );

                const cantidad = parseInt(cantidades[index].value) || 0;
                total += precio * cantidad;
            }
        });

        document.getElementById("total").innerText = "$" + total.toFixed(2);
    }

    checkboxes.forEach(c => c.addEventListener("change", calcularTotal));
    cantidades.forEach(c => c.addEventListener("input", calcularTotal));

    calcularTotal();
</script>