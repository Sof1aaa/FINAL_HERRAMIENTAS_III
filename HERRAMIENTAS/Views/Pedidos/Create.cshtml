@model dynamic

<div class="container d-flex justify-content-center mt-5">

    <div class="card p-4 shadow" style="width: 600px;">

        <h3 class="mb-4">Crear Pedido</h3>

        <form asp-action="Create">
            @Html.AntiForgeryToken()

            <div class="mb-4">
                <label class="form-label">Cliente</label>
                <select name="ClienteId" asp-items="ViewBag.Clientes" class="form-control"></select>
            </div>

            <h5 class="mb-3">Productos</h5>

            <div class="list-group mb-4">

                @foreach (var producto in ViewBag.Productos)
                {
                    <div class="list-group-item d-flex justify-content-between align-items-center">

                        <div>
                            <input type="checkbox" name="ProductoIds" value="@producto.Id" class="form-check-input me-2" />
                            <span>@producto.Nombre</span>
                            <small class="text-muted">($@producto.Precio.ToString("0.##"))</small>
                        </div>

                        <input type="number"
                               name="Cantidades"
                               value="0"
                               min="0"
                               class="form-control"
                               style="width: 80px;" />
                    </div>
                }

            </div>

            <button type="submit" class="btn btn-dark w-100 mt-3">
                Guardar Pedido
            </button>

        </form>

    </div>

</div>